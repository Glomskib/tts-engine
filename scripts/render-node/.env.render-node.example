# FlashFlow Render Node — Environment Variables
# Copy this to .env and fill in your values

# Your deployed FlashFlow app URL (no trailing slash)
FLASHFLOW_API_URL=https://your-app.vercel.app

# Shared secret — must match RENDER_NODE_SECRET in Vercel env vars
RENDER_NODE_SECRET=your-secret-here

# Unique name for this Mac mini (shows up in job tracking)
RENDER_NODE_ID=mac-mini-studio-1

# Supabase — for uploading final renders to storage
SUPABASE_URL=https://qqyrwwvtxzrwbyqegpme.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — for GPT-4o Vision + Whisper
OPENAI_API_KEY=sk-...
