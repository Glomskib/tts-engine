#!/usr/bin/env bash
# mc-post — Brandon's CLI front door for the FlashFlow marketing pipeline.
#
# Subcommands:
#   list [--status pending|scheduled|published|failed|cancelled] [--limit N]
#       Recent marketing_posts rows. Default: latest 10 across all statuses.
#
#   pending [--brand BRAND] [--platform PLATFORM]
#       Posts waiting on Brandon's approval. Shows ID, when, brand,
#       platform, claim-risk score, and the first ~140 chars of body.
#
#   approve <id> [--note "context"]
#       Marks the post meta.approved=true. The marketing-scheduler cron
#       (every 15 min) will then ship it to Late.dev — but ONLY if the
#       MARKETING_AUTOPUBLISH env var is also set to 'on' in Vercel.
#
#   reject <id> [--reason "why"]
#       Marks the post status='cancelled'. Will not publish.
#
# Auth:
#   Requires MISSION_CONTROL_TOKEN in env. Add it to ~/.zshrc:
#     export MISSION_CONTROL_TOKEN="..."     # from Vercel envs
#     export FLASHFLOW_BASE_URL="https://flashflowai.com"   # optional override
#
# Install:
#   ln -s "$(pwd)/bin/mc-post" ~/.local/bin/mc-post
#   (assumes ~/.local/bin is in PATH)
#
# Created 2026-05-30 as part of the approval-gate fix for unapproved FB posts.

set -euo pipefail

BASE_URL="${FLASHFLOW_BASE_URL:-https://flashflowai.com}"
TOKEN="${MISSION_CONTROL_TOKEN:-}"

die() { printf "mc-post: %s\n" "$*" >&2; exit 1; }

[[ -n "$TOKEN" ]] || die "MISSION_CONTROL_TOKEN env var is required. Add it to ~/.zshrc."

# Requires curl + python3 (both stock on macOS).
command -v curl >/dev/null   || die "curl not found"
command -v python3 >/dev/null || die "python3 not found"

http_get() {
  local path="$1"
  curl -sS -X GET "${BASE_URL}${path}" \
    -H "Authorization: Bearer ${TOKEN}" \
    -H "Accept: application/json"
}

http_post() {
  local path="$1"; shift
  local body="${1:-{\}}"
  curl -sS -X POST "${BASE_URL}${path}" \
    -H "Authorization: Bearer ${TOKEN}" \
    -H "Content-Type: application/json" \
    -H "Accept: application/json" \
    -d "$body"
}

# ── pretty-print helpers using python (avoids jq dependency) ───────────
print_list() {
  python3 - <<'PY'
import json, sys, textwrap
data = json.load(sys.stdin)
if not data.get("ok"):
    print("ERROR:", data.get("error") or data, file=sys.stderr); sys.exit(1)
posts = data.get("posts") or []
if not posts:
    print("(no posts)")
    sys.exit(0)
for p in posts:
    pid = p.get("id", "")
    status = p.get("status") or "?"
    src = p.get("source") or "?"
    risk = p.get("claim_risk_score")
    plats = p.get("platforms") or []
    if isinstance(plats, list):
        plats_s = ",".join(
            (x.get("platform") if isinstance(x, dict) else str(x)) for x in plats
        ) or "-"
    else:
        plats_s = "-"
    body = (p.get("content") or "").strip().replace("\n", " ")
    preview = textwrap.shorten(body, width=110, placeholder="…")
    created = (p.get("created_at") or "")[:19].replace("T", " ")
    print(f"{pid[:8]}  {status:9s}  {plats_s:25s}  risk={str(risk):>3s}  {src:18s}  {created}")
    print(f"          {preview}")
PY
}

print_pending() {
  python3 - <<'PY'
import json, sys, textwrap
data = json.load(sys.stdin)
if not data.get("ok"):
    print("ERROR:", data.get("error") or data, file=sys.stderr); sys.exit(1)
posts = data.get("posts") or []
env_on = data.get("autopublish_env") == "on"
banner = "[autopublish=ON]" if env_on else "[autopublish=OFF — approve will record, but cron is paused]"
print(banner)
if not posts:
    print("(no posts awaiting approval)")
    sys.exit(0)
print(f"{len(posts)} post(s) awaiting approval:\n")
for p in posts:
    pid = p.get("id", "")
    plats = p.get("platforms") or []
    if isinstance(plats, list):
        plats_s = ",".join(
            (x.get("platform") if isinstance(x, dict) else str(x)) for x in plats
        ) or "-"
    else:
        plats_s = "-"
    risk = p.get("claim_risk_score")
    src = p.get("source") or "?"
    sched = (p.get("scheduled_for") or "")[:19].replace("T", " ")
    body = (p.get("content") or "").strip()
    preview = textwrap.shorten(body.replace("\n", " "), width=110, placeholder="…")
    print(f"id: {pid}")
    print(f"   platforms: {plats_s}   risk: {risk}   source: {src}   sched: {sched or '-'}")
    print(f"   {preview}")
    print(f"   approve:  mc-post approve {pid}")
    print(f"   reject :  mc-post reject  {pid}")
    print()
PY
}

print_single() {
  python3 - <<'PY'
import json, sys
data = json.load(sys.stdin)
if not data.get("ok"):
    print("ERROR:", data.get("error") or data, file=sys.stderr); sys.exit(1)
print(json.dumps(data, indent=2))
PY
}

cmd_list() {
  local status="" limit="10"
  while (( $# )); do
    case "$1" in
      --status) status="$2"; shift 2 ;;
      --limit)  limit="$2"; shift 2 ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  local qs="?limit=${limit}"
  [[ -n "$status" ]] && qs="${qs}&status=${status}"
  http_get "/api/marketing/enqueue${qs}" | print_list
}

cmd_pending() {
  local brand="" platform=""
  while (( $# )); do
    case "$1" in
      --brand)    brand="$2"; shift 2 ;;
      --platform) platform="$2"; shift 2 ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  local qs="?limit=50"
  [[ -n "$brand"    ]] && qs="${qs}&brand=$(python3 -c 'import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))' "$brand")"
  [[ -n "$platform" ]] && qs="${qs}&platform=${platform}"
  http_get "/api/marketing/pending${qs}" | print_pending
}

cmd_approve() {
  local id="${1:-}"; shift || true
  [[ -n "$id" ]] || die "usage: mc-post approve <id> [--note 'context']"
  local note=""
  while (( $# )); do
    case "$1" in
      --note) note="$2"; shift 2 ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  local body='{"approver":"brandon"}'
  if [[ -n "$note" ]]; then
    body=$(python3 -c 'import json,sys; print(json.dumps({"approver":"brandon","note":sys.argv[1]}))' "$note")
  fi
  http_post "/api/marketing/posts/${id}/approve" "$body" | print_single
}

cmd_reject() {
  local id="${1:-}"; shift || true
  [[ -n "$id" ]] || die "usage: mc-post reject <id> [--reason 'why']"
  local reason="rejected by brandon"
  while (( $# )); do
    case "$1" in
      --reason) reason="$2"; shift 2 ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  local body
  body=$(python3 -c 'import json,sys; print(json.dumps({"approver":"brandon","reason":sys.argv[1]}))' "$reason")
  http_post "/api/marketing/posts/${id}/reject" "$body" | print_single
}

cmd_sync_pages() {
  # mc-post sync-pages [--dry-run] [--map FILE] [--zernio-key KEY]
  local dry_run=false
  local map_file=""
  local zkey="${ZERNIO_API_KEY:-${LATE_API_KEY:-}}"
  while (( $# )); do
    case "$1" in
      --dry-run)     dry_run=true; shift ;;
      --map)         map_file="$2"; shift 2 ;;
      --zernio-key)  zkey="$2"; shift 2 ;;
      *) die "unknown arg: $1" ;;
    esac
  done

  local map_json="{}"
  if [[ -n "$map_file" ]]; then
    [[ -f "$map_file" ]] || die "map file not found: $map_file"
    map_json=$(cat "$map_file")
  fi

  local body
  body=$(python3 -c '
import json, sys
m = json.loads(sys.argv[1])
dr = sys.argv[2] == "true"
k = sys.argv[3]
payload = {"parent_brand_map": m, "dry_run": dr}
if k: payload["zernio_api_key"] = k
print(json.dumps(payload))
' "$map_json" "$dry_run" "$zkey")

  http_post "/api/marketing/sync-zernio-pages" "$body" | python3 -m json.tool
}

cmd_summary() {
  http_get "/api/marketing/pending-summary" | python3 -m json.tool
}

cmd_bulk_cancel() {
  # mc-post bulk-cancel [--older-than N] [--source X] [--contains X] [--dry-run] [--reason "..."]
  local older="" src="" contains="" dry=false reason="bulk-cancel by brandon"
  while (( $# )); do
    case "$1" in
      --older-than) older="$2"; shift 2 ;;
      --source)     src="$2"; shift 2 ;;
      --contains)   contains="$2"; shift 2 ;;
      --dry-run)    dry=true; shift ;;
      --reason)     reason="$2"; shift 2 ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  if [[ -z "$older" && -z "$src" && -z "$contains" ]]; then
    die "must specify at least one of: --older-than N | --source X | --contains X"
  fi
  local body
  body=$(python3 -c '
import json,sys
o=sys.argv[1]; s=sys.argv[2]; c=sys.argv[3]; d=sys.argv[4]; r=sys.argv[5]
p={"reason":r,"dry_run":d=="true"}
if o: p["older_than_days"]=int(o)
if s: p["source"]=s
if c: p["source_contains"]=c
print(json.dumps(p))
' "$older" "$src" "$contains" "$dry" "$reason")
  http_post "/api/marketing/bulk-cancel" "$body" | python3 -m json.tool
}

cmd_pages() {
  # mc-post pages — list every brand_account row in DB (uses /api/marketing/enqueue GET
  # is not quite right; use a dedicated query through pending endpoint to discover).
  # For now, just print a friendly hint to the admin URL.
  cat <<HINT
mc-post pages — to list every connected farm page + umbrella:
  curl -sS -H "Authorization: Bearer \$MISSION_CONTROL_TOKEN" \\
    "${BASE_URL}/api/admin/marketing/brand-accounts" | python3 -m json.tool

(Or open ${BASE_URL}/admin/marketing/queue in the browser.)

Quick run: mc-post sync-pages --dry-run     # see what would happen
           mc-post sync-pages --map ./farm-map.json   # actually sync
HINT
}

usage() {
  cat <<USAGE
mc-post — FlashFlow marketing CLI

Approval flow:
  mc-post list     [--status STATUS] [--limit N]
  mc-post pending  [--brand BRAND] [--platform PLATFORM]
  mc-post approve  <id> [--note "context"]
  mc-post reject   <id> [--reason "why"]

Triage:
  mc-post summary                          counts pending: by source, by age, recommended action
  mc-post bulk-cancel --older-than N       cancel all unapproved pending posts older than N days
                      --source X           cancel all pending from source X
                      --contains X         cancel all pending where source contains X
                      --dry-run            preview first (always recommended)
                      --reason "..."       free-text reason recorded on each cancellation

Farm management (multi-page-per-umbrella):
  mc-post pages                            show how to list connected pages
  mc-post sync-pages [--dry-run]           pull every Zernio FB page → brand_accounts
                     [--map FILE]          --map FILE: JSON of {pageName: umbrellaBrand}
                     [--zernio-key KEY]    override LATE_API_KEY env (or set ZERNIO_API_KEY in shell)

Env:
  MISSION_CONTROL_TOKEN   required (Vercel env value)
  FLASHFLOW_BASE_URL      default https://flashflowai.com
USAGE
}

sub="${1:-}"; shift || true
case "$sub" in
  list)        cmd_list "$@" ;;
  pending)     cmd_pending "$@" ;;
  approve)     cmd_approve "$@" ;;
  reject)      cmd_reject "$@" ;;
  summary)     cmd_summary "$@" ;;
  bulk-cancel) cmd_bulk_cancel "$@" ;;
  sync-pages)  cmd_sync_pages "$@" ;;
  pages)       cmd_pages "$@" ;;
  ""|-h|--help|help) usage ;;
  *) die "unknown subcommand: $sub (try 'mc-post help')" ;;
esac
