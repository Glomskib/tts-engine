<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  OpenClaw Worker — Wife Slot

  Install:
    cp scripts/slot/com.flashflow.openclaw.worker.wife.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.flashflow.openclaw.worker.wife.plist

  Unload:
    launchctl unload ~/Library/LaunchAgents/com.flashflow.openclaw.worker.wife.plist
-->
<dict>
    <key>Label</key>
    <string>com.flashflow.openclaw.worker.wife</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/brandonglomski/tts-engine/web/scripts/slot/run-worker.sh</string>
        <string>--slot</string>
        <string>wife</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/brandonglomski/tts-engine/web</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/brandonglomski/tts-engine/web/logs/workers/openclaw_worker.wife.launchd.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/brandonglomski/tts-engine/web/logs/workers/openclaw_worker.wife.launchd.stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/brandonglomski</string>
        <key>FF_SLOT</key>
        <string>wife</string>
    </dict>
</dict>
</plist>
