# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# marketing brand account config (contains Late.dev account IDs)
brand-accounts.local.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase
/supabase/.temp/
.env*.local
bin/

# debug screenshots and logs
/data/trending/daily-virals/screenshots/
/logs/

# browser sessions (contain cookies — never commit)
/data/sessions/

# TikTok error screenshots and reports
/data/tiktok-errors/

# Regression test reports
/var/run-reports/**

# RI ingestion run lock
.ri-ingestion.lock

# Client slot config (contains UUIDs — never commit)
config/client-slots.json
