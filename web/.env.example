# ---- Inngest (AI Video Editor background processing) ----
# In local dev: run `npx inngest-cli@latest dev` — no keys required.
# In production: get these from https://app.inngest.com (App: flashflow)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
