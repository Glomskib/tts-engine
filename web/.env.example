# ===========================================
# FlashFlow AI - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# -------------------------------------------
# REQUIRED: Supabase Configuration
# -------------------------------------------
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------
# REQUIRED: AI Services
# -------------------------------------------
# Anthropic API Key - for Claude AI (skit generation, scoring)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API Key - for Whisper transcription (TikTok Transcriber)
# Get your key at https://platform.openai.com
OPENAI_API_KEY=sk-your-key-here

# Replicate API Token - for AI image generation (B-Roll Generator)
# Get your token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-token-here

# ElevenLabs API Key - for text-to-speech (optional)
# Get your key at https://elevenlabs.io
# ELEVENLABS_API_KEY=your-key-here

# -------------------------------------------
# REQUIRED: Application URL
# -------------------------------------------
# Your app's public URL (used for callbacks, emails)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# App version (shown in system health page)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# -------------------------------------------
# OPTIONAL: Stripe Payments
# -------------------------------------------
# Required for subscription billing
# STRIPE_SECRET_KEY=sk_live_your-key-here
# STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here

# Stripe Price IDs — New 5-Tier Model
# STRIPE_PRICE_CREATOR_LITE=price_xxx      # Creator Lite $9/mo
# STRIPE_PRICE_CREATOR_PRO=price_xxx       # Creator Pro $29/mo
# STRIPE_PRICE_BRAND=price_xxx             # Brand $49/mo
# STRIPE_PRICE_AGENCY=price_xxx            # Agency $149/mo

# Stripe Price IDs — Editing Add-ons
# STRIPE_PRICE_EDITING_ONLY=price_xxx      # Editing Only $19/mo (15 edits)
# STRIPE_PRICE_EDITING_ADDON=price_xxx     # Extra Edits Pack $10/mo (10 edits)
# STRIPE_PRICE_PER_VIDEO=price_xxx         # Single Video Edit $3 (one-time)

# Stripe Connect — Affiliate Payouts
# STRIPE_CONNECT_CLIENT_ID=ca_xxx

# Legacy Stripe Price IDs (backwards compat)
# STRIPE_PRICE_STARTER_MONTHLY=price_xxx
# STRIPE_PRICE_STARTER_YEARLY=price_xxx
# STRIPE_PRICE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_YEARLY=price_xxx
# STRIPE_PRICE_TEAM_MONTHLY=price_xxx
# STRIPE_PRICE_TEAM_YEARLY=price_xxx

# -------------------------------------------
# OPTIONAL: Email Configuration (SendGrid — legacy)
# -------------------------------------------
# EMAIL_ENABLED=true
# SENDGRID_API_KEY=SG.your-sendgrid-key
# EMAIL_FROM=noreply@yourdomain.com
# OPS_EMAIL_TO=ops@yourdomain.com

# -------------------------------------------
# OPTIONAL: Email Marketing (Resend)
# -------------------------------------------
# Resend API key for onboarding, lead magnet, and winback sequences
# Get your key at https://resend.com
# RESEND_API_KEY=re_your-key-here
# RESEND_FROM_EMAIL=FlashFlow AI <hello@flashflowai.com>

# -------------------------------------------
# OPTIONAL: Slack Notifications
# -------------------------------------------
# SLACK_ENABLED=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# -------------------------------------------
# OPTIONAL: Admin & User Configuration
# -------------------------------------------
# Comma-separated list of admin user emails/IDs
# ADMIN_USERS=admin@example.com,user-uuid-here
# DEFAULT_ADMIN_EMAIL=admin@example.com

# Default user IDs for role assignments
# DEFAULT_RECORDER_USER_ID=uuid-here
# DEFAULT_EDITOR_USER_ID=uuid-here
# DEFAULT_UPLOADER_USER_ID=uuid-here

# Comma-separated list of uploader user IDs
# UPLOADER_USERS=uuid1,uuid2

# -------------------------------------------
# OPTIONAL: Feature Flags
# -------------------------------------------
# Enable/disable admin UI
# ADMIN_UI_ENABLED=true

# Enable subscription gating for premium features
# SUBSCRIPTION_GATING_ENABLED=false

# Comma-separated list of pro user IDs (bypass subscription checks)
# PRO_USER_IDS=uuid1,uuid2

# -------------------------------------------
# OPTIONAL: Winner/Performance Thresholds
# -------------------------------------------
# Minimum views to qualify as a winner
# WINNER_MIN_VIEWS=10000

# Minimum orders to qualify as a winner
# WINNER_MIN_ORDERS=100

# -------------------------------------------
# OPTIONAL: Debug Settings
# -------------------------------------------
# Enable AI debug logging (shows prompts and responses)
# DEBUG_AI=false

# Enable test IDs in production (for testing)
# ENABLE_TEST_IDS=false

# -------------------------------------------
# OPTIONAL: Telegram Notifications
# -------------------------------------------
# Bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your-bot-token-here
# Chat ID to send messages to (use @userinfobot to find yours)
# TELEGRAM_CHAT_ID=your-chat-id-here

# -------------------------------------------
# OPTIONAL: TikTok Shop Scraping
# -------------------------------------------
# ScrapeCreators API key for importing TikTok Shop products
# Get your key at https://scrapecreators.com
# SCRAPECREATORS_API_KEY=your-api-key-here

# -------------------------------------------
# OPTIONAL: Local AI (Ollama)
# -------------------------------------------
# Ollama URL for local LLM inference (used as fallback for simple tasks)
# Install: brew install ollama && ollama serve && ollama pull llama3.1
# OLLAMA_URL=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=llama3.1

# -------------------------------------------
# OPTIONAL: Deployment & Cron
# -------------------------------------------
# Vercel deploy hook URL for triggering deploys
# VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/xxx
# Secret for authenticating cron job requests
# CRON_SECRET=your-cron-secret-here

# -------------------------------------------
# OPTIONAL: Sentry Error Tracking
# -------------------------------------------
# Get your DSN from https://sentry.io > Project Settings > Client Keys (DSN)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=1.0.0
# SENTRY_AUTH_TOKEN=sntrys_your-token-here  # For source map upload only

# -------------------------------------------
# OPTIONAL: Marketing Engine (Late.dev)
# -------------------------------------------
# Late.dev API key for social media scheduling
# LATE_API_KEY=your-late-api-key-here
# Set to 'true' to test without actually posting (dry-run)
# LATE_DRY_RUN=true

# -------------------------------------------
# OPTIONAL: Shotstack Video Rendering
# -------------------------------------------
# Shotstack API keys for programmatic video rendering
# Get your keys at https://dashboard.shotstack.io
# SHOTSTACK_SANDBOX_KEY=your-sandbox-key-here
# SHOTSTACK_PRODUCTION_KEY=your-production-key-here
# SHOTSTACK_ENV=sandbox

# -------------------------------------------
# OPTIONAL: Runway AI Video Generation
# -------------------------------------------
# Runway API key for AI video generation (text-to-video, image-to-video)
# Get your key at https://app.runwayml.com/settings/api-keys
# RUNWAY_API_KEY=your-runway-api-key-here

# -------------------------------------------
# OPTIONAL: HeyGen Avatar Video Generation
# -------------------------------------------
# HeyGen API key for talking-head avatar videos
# Get your key at https://app.heygen.com (Settings > API)
# HEYGEN_API_KEY=your-heygen-api-key-here

# -------------------------------------------
# Telegram notifications for pipeline events
# Create a bot via @BotFather, get the token, add the bot to a group, get the chat ID
# TELEGRAM_BOT_TOKEN=your-bot-token-here
# TELEGRAM_CHAT_ID=your-chat-id-here

# -------------------------------------------
# OPTIONAL: Mission Control Integration
# -------------------------------------------
# Base URL of your Mission Control instance (for hook bank import, etc.)
# MISSION_CONTROL_BASE_URL=http://127.0.0.1:3100
# Agent token for authenticating with Mission Control API
# MISSION_CONTROL_AGENT_TOKEN=mc-agent-token-2026
# Weekly Trainer admin token (used to post recommendation docs)
# MC_BASE_URL=http://127.0.0.1:3100
# MC_API_TOKEN=your-mc-admin-token-here

# -------------------------------------------
# OPTIONAL: CRM Outlook Email Sync
# -------------------------------------------
# Microsoft Graph API credentials for CRM email sync
# Register an app at https://portal.azure.com > App registrations
# OUTLOOK_CLIENT_ID=your-client-id-here
# OUTLOOK_CLIENT_SECRET=your-client-secret-here
# OUTLOOK_TENANT_ID=your-tenant-id-here
# OUTLOOK_REFRESH_TOKEN=your-refresh-token-here
# Comma-separated sender emails to watch for auto-import
# CRM_WATCHED_SENDERS=partner@example.com,sponsor@example.com

# -------------------------------------------
# OPTIONAL: Discord Integration
# -------------------------------------------
# Discord OAuth app credentials (https://discord.com/developers/applications)
# DISCORD_CLIENT_ID=your-client-id-here
# DISCORD_CLIENT_SECRET=your-client-secret-here
# Discord bot token for role management
# DISCORD_BOT_TOKEN=your-bot-token-here
# Discord server (guild) ID
# DISCORD_GUILD_ID=your-guild-id-here
# Role IDs for automatic assignment
# DISCORD_PAID_ROLE_ID=your-paid-role-id-here
# DISCORD_AGENCY_BRAND_ROLE_ID=your-agency-brand-role-id-here
# Shared secret for bot → app API calls (role-state endpoint)
# BOT_SHARED_SECRET=your-shared-secret-here
# App URL used by the bot stub (default: https://app.flashflow.so)
# FLASHFLOW_URL=https://app.flashflow.so

# -------------------------------------------
# OPTIONAL: Google Drive Intake Connector
# -------------------------------------------
# Google Cloud OAuth client credentials for Drive Intake
# Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_DRIVE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_DRIVE_CLIENT_SECRET=GOCSPX-your-secret-here
# GOOGLE_DRIVE_REDIRECT_URI=https://your-domain.com/api/intake/google/callback

# 32-byte base64 key for encrypting OAuth refresh tokens at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# DRIVE_TOKEN_ENCRYPTION_KEY=your-base64-key-here

# Drive Intake Limits (all optional — sensible defaults are built in)
# MAX_INTAKE_FILE_BYTES=1610612736    # Max file size in bytes (default 1.5 GB)
# MAX_INTAKE_MINUTES=60               # Max video duration in minutes (default 60)
# MAX_FILES_PER_MONTH=200             # Max files per user per month (default 200)
# MAX_MINUTES_PER_MONTH=1000          # Max total minutes per user per month (default 1000)

# -------------------------------------------
# AUTOMATIC: Set by Vercel (don't set manually)
# -------------------------------------------
# VERCEL_URL - automatically set by Vercel deployment
# NODE_ENV - automatically set (development/production)

